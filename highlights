.highlight {
  background-color: #1e1e2f; /* Dark background */
  color: #f8f8f2; /* Light text color */
  border-radius: 5px;
  padding: 10px;
  overflow-x: auto;
}

.highlight .keyword {
  color: #66d9ef; /* Cyan for keywords */
}

.highlight .string {
  color: #f1fa8c; /* Yellow for strings */
}

.highlight .comment {
  color: #6272a4; /* Gray for comments */
  font-style: italic;
}

.highlight .function {
  color: #50fa7b; /* Green for functions */
}

.highlight .variable {
  color: #ff79c6; /* Pink for variables */
}

.highlight .number {
  color: #bd93f9; /* Purple for numbers */
}

.highlight .operator {
  color: #ff5555; /* Red for operators */
}

.highlight .class-name {
  color: #8be9fd; /* Light blue for class names */
}

.highlight .method {
  color: #ffb86c; /* Orange for methods */
}